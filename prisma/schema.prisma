generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?

  products    Product[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String        @id @default(cuid())

  name        String
  slug        String        @unique

  description String?

  price       Decimal       @db.Decimal(10, 2)

  stock       Int           @default(0)

  status      ProductStatus @default(DRAFT)

  imageUrl    String?

  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId])
  @@index([status])
}